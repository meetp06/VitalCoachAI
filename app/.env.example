# VitalCoach Environment Configuration
# Copy this file to .env and fill in values

# ─── Google DeepMind (Gemini) ──────────────────────
# Optional: Gemini API key for live AI meal analysis, voice interpretation, and insights.
# Leave blank to use demo/mock mode (fully functional without a key).
VITE_GEMINI_API_KEY=

# ─── Health Data API ───────────────────────────────
# The Cloudflare Worker that serves health data.
# Default: proxied through Vite dev server (see vite.config.ts)
VITE_API_URL=https://vita-cloud.hrishikesha40.workers.dev

# ─── App Config ────────────────────────────────────
# Port for the Vite dev server
PORT=5173
